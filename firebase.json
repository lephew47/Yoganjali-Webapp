{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "your-backend-service-id",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },

  "apphosting": {
    "build": {
      "builder": "nodejs18"
    },
    "env": {
      "GEMINI_API_KEY": {
        "secret": "GEMINI_API_KEY"
      }
    }
  },

  "emulators": {
    "hosting": { "port": 5000 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "port": 4000 }
  }
}
